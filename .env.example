# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:cloud

# Alternative models:
# OLLAMA_MODEL=qwen2.5-coder:7b   # Local, code-focused
# OLLAMA_MODEL=llama3.2           # Local, general purpose
# OLLAMA_MODEL=glm-5:cloud        # Cloud, code generation
# OLLAMA_MODEL=minimax-m2.7:cloud # Cloud, fast and efficient

# Database Connections (Optional - can be provided via CLI)
# DB_TYPE=mysql|postgresql|sqlite|mssql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=mydb

# SQLite
# SQLITE_PATH=./data/database.db

# Application Settings
LOG_LEVEL=info
MAX_SCHEMA_TABLES=50
QUERY_TIMEOUT=30000
ENABLE_MEMORY=true
