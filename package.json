{
  "name": "dbx",
  "version": "1.0.0",
  "description": "AI-Powered Database Intelligence Assistant - Natural language to SQL with Ollama",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "dbx": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "repl": "tsx src/index.ts repl",
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "database",
    "ai",
    "sql",
    "ollama",
    "cli",
    "natural-language"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "inquirer": "^9.2.15",
    "knex": "^3.1.0",
    "mysql2": "^3.9.2",
    "pg": "^8.11.3",
    "sqlite3": "^5.1.7",
    "mssql": "^10.0.2",
    "cli-table3": "^0.6.3",
    "ora": "^8.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/inquirer": "^9.0.7",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
